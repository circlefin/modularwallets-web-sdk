{
  "$schema": "https://turborepo.dev/schema.json",
  "remoteCache": {
    "signature": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["check:type", "^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": []
    },
    "test:coverage": {
      "outputs": ["coverage/**", "junit.xml"]
    },
    "lint": {
      "outputs": []
    },
    "lint:report": {
      "outputs": ["eslint_report.json"]
    },
    "check:type": {
      "outputs": []
    }
  }
}
